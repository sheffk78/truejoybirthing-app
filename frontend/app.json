{
  "expo": {
    "name": "True Joy Birthing",
    "slug": "truejoybirthing",
    "version": "1.0.14",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "truejoybirthing",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*",
      "./assets/fonts/*.ttf"
    ],
    "ios": {
      "supportsTablet": true,
      "deploymentTarget": "16.0",
      "bundleIdentifier": "com.truejoybirthing.app",
      "buildNumber": "127",
      "teamId": "A3DU82XQTJ",
      "infoPlist": {
        "SKAdNetworkItems": [],
        "NSCameraUsageDescription": "True Joy Birthing needs camera access to take profile photos.",
        "NSPhotoLibraryUsageDescription": "True Joy Birthing needs photo library access to select profile photos.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#9B6B9E"
      },
      "edgeToEdgeEnabled": false,
      "package": "com.truejoybirthing.app",
      "versionCode": 127,
      "permissions": [
        "com.android.vending.BILLING",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "True Joy Birthing needs photo library access to select profile photos.",
          "cameraPermission": "True Joy Birthing needs camera access to take profile photos."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F8F4F9"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#9F83B6"
        }
      ],
      "@react-native-community/datetimepicker",
      [
        "expo-iap",
        {
          "modules": {
            "onside": false
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "62708679-6031-4e8c-87d9-24e338d149cf"
      }
    },
    "owner": "sheffkventures",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/62708679-6031-4e8c-87d9-24e338d149cf"
    }
  }
}
