{
  "expo": {
    "name": "True Joy Birthing",
    "slug": "true-joy-birthing",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "truejoybirthing",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "assetBundlePatterns": [
      "**/*",
      "./assets/fonts/*.ttf"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.truejoybirthing.app",
      "buildNumber": "1",
      "infoPlist": {
        "SKAdNetworkItems": [],
        "NSCameraUsageDescription": "True Joy Birthing needs camera access to take profile photos.",
        "NSPhotoLibraryUsageDescription": "True Joy Birthing needs photo library access to select profile photos.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#9B6B9E"
      },
      "edgeToEdgeEnabled": false,
      "package": "com.truejoybirthing.app",
      "versionCode": 103,
      "permissions": [
        "com.android.vending.BILLING",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-image.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F8F4F9"
        }
      ],
      [
        "react-native-iap",
        {
          "paymentProvider": "both"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    },
    "owner": "truejoybirthing",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/YOUR_EAS_PROJECT_ID"
    }
  }
}
