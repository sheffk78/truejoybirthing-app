{
  "expo": {
    "name": "True Joy Birthing",
    "slug": "true-joy-birthing",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "truejoybirthing",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "assetBundlePatterns": [
      "**/*",
      "./assets/fonts/*.ttf"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.truejoybirthing.app",
      "infoPlist": {
        "SKAdNetworkItems": []
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#9B6B9E"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.truejoybirthing.app",
      "permissions": [
        "com.android.vending.BILLING"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F8F4F9"
        }
      ],
      [
        "react-native-iap",
        {
          "paymentProvider": "both"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
